{
  "appId": "com.citycar.app",
  "appName": "CityCAR",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "capacitor",
    "cleartext": true
  },
  "ios": {
    "contentInset": "always",
    "allowsLinkPreview": false,
    "scrollEnabled": true,
    "backgroundColor": "#F5F5F5",
    "preferredContentMode": "mobile"
  },
  "android": {
    "backgroundColor": "#F5F5F5",
    "allowMixedContent": false,
    "captureInput": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1E3A5F",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    },
    "Camera": {
      "ios": {
        "allowEditing": false,
        "resultType": "uri"
      }
    }
  }
}
